<!doctype html>
<html lang="pt-br">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Flying High Shoes</title>
    <link
      rel="stylesheet"
      href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css"
    />
    <link rel="stylesheet" href="style.css" />
  </head>
  <body>
    <div id="icones">
      <img
        src="data:image/png;base64,"
        alt=""
        width="50%"
        style="cursor: pointer"
        id="carrinho"
      />

      <img
        src="data:image/png;base64,"
        alt="barrinhas"
        width="50%"
        style="cursor: pointer"
        id="barrinhas"
      />
      <aside id="menu-lateral" class="sidebar">
        <div class="sidebar-header">
          <span style="font-size: 1.5em">Menu</span>
          <button id="btn-fechar">&times;</button>
        </div>
        <nav>
          <a href="FlyingHighShoes.html">Home</a>
          <a href="#promoçoes">Promoções</a>
          <a href="#marcas_disponiveis">Marcas Disponíveis</a>
          <a href="#informaçoes">Sobre</a>
        </nav>
      </aside>

      <div id="overlay" class="overlay"></div>

      <button><a href="login_site.html">Login</a></button>
    </div>
    <header>
      <center>
        <img src="logo.png" alt="logo" id="logo" />
      </center>
    </header>

    <hr
      style="
        border: none;
        height: 350px;
        background-color: deepskyblue;
        margin-top: -330px;
      "
    />
    <h1 id="chamada">
      A sua principal escolha para encontrar os melhores tênis com preços
      imbatíveis.
    </h1>
    <h2 id="promoçoes">🔥Promoções!🏷️</h2>

    <span style="display: flex; gap: 15px">
      <div class="card-produto">
        <img
          src="data:image/webp;base64,"
          alt="Tênis puma"
          class="imagem-produto"
        />
        <div class="info-produto">
          <h3 class="titulo-produto">Puma Suede XL</h3>

          De:R$<span class="preco-anterior"> 650,90</span>
          <span class="desconto">40% OFF</span>
          <span class="preco-produto">Por: R$ 399,99</span>
          <button class="botao-comprar">Comprar Agora</button>
        </div>
      </div>

      <div class="card-produto">
        <img
          src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcQ2WvigYBeQEwtjp1dYSCo2K2OVwLW6K4thkQ&s"
          alt="Tênis nike"
          class="imagem-produto"
        />
        <div class="info-produto">
          <h3 class="titulo-produto">Nike Air Max Sc</h3>

          De:R$<span class="preco-anterior"> 699,99</span>
          <span class="desconto">20% OFF</span>
          <span class="preco-produto">Por: R$ 549,99</span>
          <button class="botao-comprar">Comprar Agora</button>
        </div>
      </div>

      <div class="card-produto">
        <img
          src="data:image/jpeg;base64,"
          alt="Tênis adidas"
          class="imagem-produto"
        />
        <div class="info-produto">
          <h3 class="titulo-produto">Adidas Campus 00s</h3>

          De:R$<span class="preco-anterior"> 629,99</span>
          <span class="desconto">20% OFF</span>
          <span class="preco-produto">Por: R$ 499,99</span>
          <button class="botao-comprar">Comprar Agora</button>
        </div>
      </div>

      <div class="card-produto">
        <img
          src="data:image/jpeg;base64,"
          alt="Tênis nike"
          class="imagem-produto"
        />
        <div class="info-produto">
          <h3 class="titulo-produto">Nike Air Force 1</h3>

          De:R$<span class="preco-anterior"> 849,99</span>
          <span class="desconto">30% OFF</span>
          <span class="preco-produto">Por: R$ 599,99</span>
          <button class="botao-comprar">Comprar Agora</button>
        </div>
      </div>
    </span>

    <h2 id="marcas_disponiveis">Marcas Disponíveis</h2>
    <div id="marcas">
      <a href="nike.html" id="nike">
        <img
          src="data:image/png;base64,"
          alt="logo nike"
        />
      </a>

      <a href="adidas.html" id="adidas">
        <img
          src="https://encrypted-tbn0.gstatic.com/images?q=tbn:ANd9GcSPV3dB48PmsIzgyJXQa29lr4KmH8CBTWDw0g&s"
          alt="logo adidas"
        />
      </a>
      <a href="puma.html" id="puma">
        <img
          src="data:image/png;base64,"
          alt="logo puma"
        />
      </a>
    </div>

    <aside id="carrinho-lateral" class="sidebar-carrinho">
      <div class="sidebar-header">
        <span style="font-size: 1.5em">Seu Carrinho</span>
        <button id="btn-fechar-carrinho">&times;</button>
      </div>

      <div id="itens-carrinho">
        <p style="text-align: center; color: #666; margin-top: 20px">
          Seu carrinho está vazio.
        </p>
      </div>

      <div class="carrinho-footer">
        <div
          style="
            display: flex;
            justify-content: space-between;
            font-size: 1.2em;
            font-weight: bold;
            margin-bottom: 15px;
          "
        >
          <span>Total:</span>
          <span>R$ <span id="valor-total">0,00</span></span>
        </div>
        <button id="btn-confirmar-compra" class="botao-comprar">
          Confirmar Compra
        </button>
      </div>
    </aside>

    <footer>
      <hr />
      <address id="informaçoes">
        <i
          class="fa-brands fa-whatsapp"
          style="color: #25d366; font-size: 30px"
        ></i>
        Contato: (22) 99285-1434
        <br />
        <br />
        <i
          class="fa-brands fa-instagram"
          style="color: blueviolet; font-size: 30px"
        ></i>
        FlyingHigh_ofc <br />
        <br />
        <p class="sobre">
          Sobre nós: Cansado de procurar em vários sites tênis com preços
          acessíveis? Aqui nós fazemos isso por você. Somos uma empresa
          responsável por filtrar os melhores preços do mercado no ramo dos
          calçados e facilitar na hora da sua procura pelo melhor par no preço
          ideal <br /><br />
        </p>
      </address>
      <form action="">
        Informe seu e-mail para podermos guardar sua opnião

        <br />

        <input type="email" />

        <br />

        <label for="comentarios"
          >Conte-nos o que achou e o que podemos melhorar
        </label>
        <br />

        <textarea name="comentarios" id="comentarios"></textarea>

        <br />

        <button type="submit">Enviar</button>
      </form>
      <p class="copyright">Direitos Reservados a Flying High Shoes®</p>
    </footer>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const btnMenu = document.getElementById('barrinhas');
        const btnFechar = document.getElementById('btn-fechar');
        const menu = document.getElementById('menu-lateral');
        const overlay = document.getElementById('overlay');

        function alternarMenu() {
          menu.classList.toggle('active');
          overlay.classList.toggle('active');
        }

        btnMenu.addEventListener('click', alternarMenu);
        btnFechar.addEventListener('click', alternarMenu);
        overlay.addEventListener('click', () => {
          menu.classList.remove('active');
          document
            .getElementById('carrinho-lateral')
            .classList.remove('active');
          overlay.classList.remove('active');
        });

        const btnCarrinho = document.getElementById('carrinho');
        const carrinhoLateral = document.getElementById('carrinho-lateral');
        const btnFecharCarrinho = document.getElementById(
          'btn-fechar-carrinho',
        );
        const listaItens = document.getElementById('itens-carrinho');
        const totalDisplay = document.getElementById('valor-total');

        let totalCusto = 0;

        btnCarrinho.addEventListener('click', () => {
          carrinhoLateral.classList.add('active');
          overlay.classList.add('active');
        });

        btnFecharCarrinho.addEventListener('click', () => {
          carrinhoLateral.classList.remove('active');
          overlay.classList.remove('active');
        });

        document.querySelectorAll('.botao-comprar').forEach((botao) => {
          botao.addEventListener('click', (e) => {
            const card = e.target.closest('.card-produto');
            const nome = card.querySelector('.titulo-produto').innerText;
            const precoTexto = card.querySelector('.preco-produto').innerText;
            if (listaItens.innerHTML.includes('Seu carrinho está vazio')) {
              listaItens.innerHTML = '';
            }

            const precoNum = parseFloat(
              precoTexto
                .replace('Por: R$ ', '')
                .replace('.', '')
                .replace(',', '.'),
            );

            const novoItem = document.createElement('p');
            novoItem.innerHTML = `<strong>${nome}</strong> - ${precoTexto}`;
            listaItens.appendChild(novoItem);

            totalCusto += precoNum;
            totalDisplay.innerText = totalCusto.toLocaleString('pt-br', {
              minimumFractionDigits: 2,
            });

            alert('Adicionado ao carrinho!');
          });
        });

        const btnConfirmar = document.getElementById('btn-confirmar-compra');

        if (btnConfirmar) {
          btnConfirmar.addEventListener('click', (e) => {
            e.stopPropagation();

            if (totalCusto > 0) {
              alert(
                'Compra finalizada com sucesso! Seu carrinho foi esvaziado.',
              );

              totalCusto = 0;

              if (totalDisplay) {
                totalDisplay.innerText = '0,00';
              }

              if (listaItens) {
                listaItens.innerHTML = '<p>Seu carrinho está vazio</p>';
              }

              carrinhoLateral?.classList.remove('active');
              overlay?.classList.remove('active');
            } else {
              alert('Adicione itens antes de confirmar a compra!');
            }
          });
        }
      });
    </script>
  </body>
</html>
